# Qwen3-TTS API env config
# Copy to qwen3tts.env before starting the service.

QWEN3_TTS_MODEL_PATH=/root/autodl-tmp/models/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN3_TTS_DEVICE=cuda:0
QWEN3_TTS_DTYPE=bfloat16
QWEN3_TTS_DEFAULT_SPEAKER=Vivian
QWEN3_TTS_DEFAULT_LANGUAGE=zh

# Optional: set to flash_attention_2 if flash-attn is installed and compatible.
QWEN3_TTS_ATTN_IMPL=

# Point these to the active conda environment on the target server.
PYTHON_BIN=/root/miniconda3/envs/qwen3-tts/bin/python
UVICORN_BIN=/root/miniconda3/envs/qwen3-tts/bin/uvicorn

# Comma-separated API keys.
QWEN3_TTS_API_KEYS=tts-key-1,tts-key-2,tts-key-3

TTS_API_HOST=0.0.0.0
TTS_API_PORT=8010
