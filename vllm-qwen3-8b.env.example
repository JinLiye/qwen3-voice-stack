MODEL_PATH=/path/to/Qwen3-8B
SERVED_MODEL_NAME=qwen3-8b
HOST=0.0.0.0
PORT=8000
DTYPE=bfloat16
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=8192
DEFAULT_SYSTEM_PROMPT=

# Point these to the active conda environment on the target server.
PYTHON_BIN=$HOME/miniconda3/envs/qwen3-vllm/bin/python
VLLM_BIN=$HOME/miniconda3/envs/qwen3-vllm/bin/vllm

# Configure one or more API keys for the OpenAI-compatible endpoint.
API_KEY_1=replace-with-your-key-1
API_KEY_2=
API_KEY_3=
API_KEY_4=
API_KEY_5=
